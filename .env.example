# gb-travio-realtime-bridge environment
# Copy to /etc/gb-travio-realtime-bridge.env (production) or .env (local dev)
# and replace the placeholders below with real values.
#
# Where to get these:
#   TRAVIO_ID / TRAVIO_KEY: from `gb-automations` Railway env vars
#     cd /root/gbbookingincentives/automations && railway variables --kv
#   WEBHOOK_ADMIN_API_KEY: from `gb-travio-webhooks` Railway env vars
#     cd /root/gb-travio-webhooks && railway variables --kv
#   NEON_DATABASE_URL: from /root/gb-travio-db/secrets/gb-udb.database-url

# Travio API credentials
TRAVIO_BASE_URL=https://api.travio.it/v2
TRAVIO_ID=replace-with-travio-client-id
TRAVIO_KEY=replace-with-travio-client-key
TRAVIO_REQUESTS_PER_MINUTE=60

# Webhook receiver (Railway) - polled for new events
WEBHOOK_BASE_URL=https://travio.gbcrm.it
WEBHOOK_ADMIN_API_KEY=replace-with-webhook-admin-key
WEBHOOK_POLL_INTERVAL_SECONDS=10
WEBHOOK_POLL_LIMIT=50

# Neon (gb-udb)
NEON_DATABASE_URL=postgresql://neondb_owner:***@your-neon-host.neon.tech/neondb?sslmode=require&channel_binding=require

# Operational
LOG_LEVEL=info
SERVICE_NAME=gb-travio-realtime-bridge
DRY_RUN=false
